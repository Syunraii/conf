[Remote Filter]
No_Filter = NameRegex, FilterKey = ".*"
# 地区过滤
Filter_HK = NameRegex, FilterKey = "(?i)🇭🇰|香港|(\b(HK|HongKong|Hong Kong)\b)"
Filter_TW = NameRegex, FilterKey = "(?i)🇨🇳|🇹🇼|台湾|(\b(TW|Taiwan)\b)"
Filter_JP = NameRegex, FilterKey = "(?i)🇯🇵|日本|(\b(JP|Japan)\b)"
Filter_KR = NameRegex, FilterKey = "(?i)🇰🇷|韩国|(\b(KR|South Korea)\b)"
Filter_US = NameRegex, FilterKey = "(?i)🇺🇸|美国|(\b(US|USA|United States)\b)"
Filter_SG = NameRegex, FilterKey = "(?i)🇸🇬|新加坡|狮城|(\b(SG|Singapore)\b)"
Filter_OT = NameRegex, FilterKey = "^(?!.*(?i)(🇭🇰|香港|(\b(HK|HongKong|Hong Kong)\b)|🇨🇳|🇹🇼|台湾|(\b(TW|Taiwan)\b)|🇯🇵|日本|(\b(JP|Japan)\b)|🇰🇷|韩国|(\b(KR|South Korea)\b)|🇺🇸|美国|(\b(US|USA|United States)\b)|🇸🇬|新加坡|狮城|(\b(SG|Singapore)\b))).*$"

Filter_Pub_HK = NameRegex,🛫 常规订阅, FilterKey = "(?i)🇭🇰|香港|(\b(HK|HongKong|Hong Kong)\b)"
Filter_Pub_TW = NameRegex,🛫 常规订阅, FilterKey = "(?i)🇨🇳|🇹🇼|台湾|(\b(TW|Taiwan)\b)"
Filter_Pub_JP = NameRegex,🛫 常规订阅, FilterKey = "(?i)🇯🇵|日本|(\b(JP|Japan)\b)"
Filter_Pub_KR = NameRegex,🛫 常规订阅, FilterKey = "(?i)🇰🇷|韩国|(\b(KR|South Korea)\b)"
Filter_Pub_US = NameRegex,🛫 常规订阅, FilterKey = "(?i)🇺🇸|美国|(\b(US|USA|United States)\b)"
Filter_Pub_SG = NameRegex,🛫 常规订阅, FilterKey = "(?i)🇸🇬|新加坡|狮城|(\b(SG|Singapore)\b)"
Filter_Pub_OT = NameRegex,🛫 常规订阅, FilterKey = "^(?!.*(?i)(🇭🇰|香港|(\b(HK|HongKong|Hong Kong)\b)|🇨🇳|🇹🇼|台湾|(\b(TW|Taiwan)\b)|🇯🇵|日本|(\b(JP|Japan)\b)|🇰🇷|韩国|(\b(KR|South Korea)\b)|🇺🇸|美国|(\b(US|USA|United States)\b)|🇸🇬|新加坡|狮城|(\b(SG|Singapore)\b))).*$"

Filter_Pri_HK = NameRegex,🛫 优质订阅, FilterKey = "(?i)🇭🇰|香港|(\b(HK|HongKong|Hong Kong)\b)"
Filter_Pri_TW = NameRegex,🛫 优质订阅, FilterKey = "(?i)🇨🇳|🇹🇼|台湾|(\b(TW|Taiwan)\b)"
Filter_Pri_JP = NameRegex,🛫 优质订阅, FilterKey = "(?i)🇯🇵|日本|(\b(JP|Japan)\b)"
Filter_Pri_KR = NameRegex,🛫 优质订阅, FilterKey = "(?i)🇰🇷|韩国|(\b(KR|South Korea)\b)"
Filter_Pri_US = NameRegex,🛫 优质订阅, FilterKey = "(?i)🇺🇸|美国|(\b(US|USA|United States)\b)"
Filter_Pri_SG = NameRegex,🛫 优质订阅, FilterKey = "(?i)🇸🇬|新加坡|狮城|(\b(SG|Singapore)\b)"
Filter_Pri_OT = NameRegex,🛫 优质订阅, FilterKey = "^(?!.*(?i)(🇭🇰|香港|(\b(HK|HongKong|Hong Kong)\b)|🇨🇳|🇹🇼|台湾|(\b(TW|Taiwan)\b)|🇯🇵|日本|(\b(JP|Japan)\b)|🇰🇷|韩国|(\b(KR|South Korea)\b)|🇺🇸|美国|(\b(US|USA|United States)\b)|🇸🇬|新加坡|狮城|(\b(SG|Singapore)\b))).*$"

# 倍率过滤
Filter_HR = NameRegex, FilterKey = "^(?=.*[2-9][0-9]*[×x]).*$"
Filter_NR = NameRegex, FilterKey = "^[^×x]*$"
Filter_LR = NameRegex, FilterKey = "^(?=.*(0\.1[×x]|0\.01[×x]|0\.1\b|0\.0[0-9])).*$"

# 地区+倍率过滤
